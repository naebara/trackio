{
  "name": "trackio",
  "version": "2026.3.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:production": "./scripts/start-production.sh",
    "lint": "eslint",
    "version:patch": "node scripts/version-bump.mjs patch",
    "version:minor": "node scripts/version-bump.mjs minor",
    "version:year": "node scripts/version-bump.mjs year",
    "setup": "node scripts/setup.js",
    "db:setup": "node scripts/db-local-setup.js",
    "db:restore-prod": "./scripts/restore-prod-db.sh",
    "db:prepare-migration": "node scripts/db-prepare-migration.js",
    "db:migrate": "npx prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:test-migration": "node scripts/test-migration.js",
    "flow": "npm run db:test-migration && npm run db:migrate && npm run db:generate && npm run dev"
  },
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^6.19.3",
    "@tabler/icons-react": "^3.40.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.564.0",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.18.0",
    "prisma": "^6.19.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
